PORT=3000
APP_PREFIX=api
# Use host.docker.internal so the same values work locally and inside Docker (Mongo/Redis on your machine).
MONGODB_URI=mongodb://host.docker.internal:27017/flight-aggregator
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000
REDIS_URL=redis://host.docker.internal:6379
SEARCH_CACHE_TTL_SECONDS=300
CACHE_KEY_VERSION=v1
DEFAULT_PAGE_LIMIT=10
MAX_PAGE_LIMIT=50
BOOKING_REFERENCE_PREFIX=BK

# JSON array — one object per provider (localhost reaches the app on host or in-container)
FLIGHT_PROVIDERS=[{"name":"ProviderA","url":"http://localhost:3000/api/mock/provider-a","enabled":true,"timeoutMs":5000},{"name":"ProviderB","url":"http://localhost:3000/api/mock/provider-b","enabled":true,"timeoutMs":5000},{"name":"ProviderC","url":"http://localhost:3000/api/mock/provider-c","enabled":true,"timeoutMs":5000}]
